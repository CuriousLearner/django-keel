services:
  web:
    build: .
    user: "${UID:-1000}:${GID:-1000}"
    command: {% if dependency_manager == 'uv' %}uv run {% endif %}{% if use_channels %}daphne -b 0.0.0.0 -p 8000 config.asgi:application{% else %}gunicorn config.wsgi:application --bind 0.0.0.0:8000 --workers 2 --reload{% endif %}
    volumes:
      - .:/app
    ports:
      - "8000:8000"
    depends_on:
      db:
        condition: service_healthy
{% if cache == 'redis' or background_tasks in ['celery', 'both'] %}
      redis:
        condition: service_healthy
{% endif %}
    environment:
      - DEBUG=True
      - DJANGO_SECRET_KEY=django-insecure-docker-dev-key
{% if database == 'postgresql' %}
      - DATABASE_URL=postgresql://{{ project_slug }}_user:{{ project_slug }}_password@db:5432/{{ project_slug }}_db
{% endif %}
{% if cache == 'redis' %}
      - REDIS_URL=redis://redis:6379/0
{% endif %}
{% if background_tasks in ['celery', 'both'] %}
      - CELERY_BROKER_URL=redis://redis:6379/1
{% endif %}
      - EMAIL_HOST=mailpit
      - EMAIL_PORT=1025
{% if dependency_manager == 'uv' %}
      - UV_NO_CACHE=1
{% endif %}
{% if frontend == 'htmx-tailwind' and frontend_bundling == 'vite' %}
      - VITE_DEV_SERVER_HOST=vite
{% endif %}
    env_file:
      - path: .env
        required: false

  db:
    image: postgres:16-alpine
    environment:
      POSTGRES_DB: {{ project_slug }}_db
      POSTGRES_USER: {{ project_slug }}_user
      POSTGRES_PASSWORD: {{ project_slug }}_password
    volumes:
      - postgres_data:/var/lib/postgresql/data
    ports:
      - "5432:5432"
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U {{ project_slug }}_user -d {{ project_slug }}_db"]
      interval: 10s
      timeout: 5s
      retries: 5
{% if cache == 'redis' or background_tasks in ['celery', 'both'] %}

  redis:
    image: redis:7-alpine
    ports:
      - "6379:6379"
    volumes:
      - redis_data:/data
    healthcheck:
      test: ["CMD", "redis-cli", "ping"]
      interval: 10s
      timeout: 5s
      retries: 5
{% endif %}
{% if background_tasks in ['celery', 'both'] %}

  celery-worker:
    build: .
    user: "${UID:-1000}:${GID:-1000}"
    command: {% if dependency_manager == 'uv' %}uv run {% endif %}celery -A config worker --loglevel=info
    volumes:
      - .:/app
    depends_on:
      db:
        condition: service_healthy
      redis:
        condition: service_healthy
    environment:
      - DEBUG=True
      - DJANGO_SECRET_KEY=django-insecure-docker-dev-key
{% if database == 'postgresql' %}
      - DATABASE_URL=postgresql://{{ project_slug }}_user:{{ project_slug }}_password@db:5432/{{ project_slug }}_db
{% endif %}
{% if cache == 'redis' %}
      - REDIS_URL=redis://redis:6379/0
{% endif %}
      - CELERY_BROKER_URL=redis://redis:6379/1
      - EMAIL_HOST=mailpit
      - EMAIL_PORT=1025
{% if dependency_manager == 'uv' %}
      - UV_NO_CACHE=1
{% endif %}
    env_file:
      - path: .env
        required: false

  celery-beat:
    build: .
    user: "${UID:-1000}:${GID:-1000}"
    command: {% if dependency_manager == 'uv' %}uv run {% endif %}celery -A config beat --loglevel=info --scheduler django_celery_beat.schedulers:DatabaseScheduler
    volumes:
      - .:/app
    depends_on:
      db:
        condition: service_healthy
      redis:
        condition: service_healthy
    environment:
      - DEBUG=True
      - DJANGO_SECRET_KEY=django-insecure-docker-dev-key
{% if database == 'postgresql' %}
      - DATABASE_URL=postgresql://{{ project_slug }}_user:{{ project_slug }}_password@db:5432/{{ project_slug }}_db
{% endif %}
{% if cache == 'redis' %}
      - REDIS_URL=redis://redis:6379/0
{% endif %}
      - CELERY_BROKER_URL=redis://redis:6379/1
      - EMAIL_HOST=mailpit
      - EMAIL_PORT=1025
{% if dependency_manager == 'uv' %}
      - UV_NO_CACHE=1
{% endif %}
    env_file:
      - path: .env
        required: false
{% endif %}

  mailpit:
    image: axllent/mailpit:latest
    ports:
      - "1025:1025"
      - "8025:8025"
{% if frontend == 'htmx-tailwind' and frontend_bundling == 'vite' %}

  vite:
    image: node:26-slim
    working_dir: /app/frontend
    volumes:
      - ./frontend:/app/frontend
      - ./static:/app/static
      - ./templates:/app/templates
    ports:
      - "5173:5173"
    command: sh -c "npm ci && npm run dev"
{% endif %}
{% if background_tasks in ['temporal', 'both'] %}

  temporal:
    image: temporalio/auto-setup:latest
    depends_on:
      - db
    environment:
      - DB=postgres12
      - DB_PORT=5432
      - POSTGRES_USER={{ project_slug }}_user
      - POSTGRES_PWD={{ project_slug }}_password
      - POSTGRES_SEEDS=db
    ports:
      - "7233:7233"
    healthcheck:
      test: ["CMD", "temporal", "workflow", "list", "--address", "temporal:7233"]
      interval: 10s
      timeout: 5s
      retries: 5

  temporal-ui:
    image: temporalio/ui:latest
    depends_on:
      - temporal
    environment:
      - TEMPORAL_ADDRESS=temporal:7233
      - TEMPORAL_CORS_ORIGINS=http://localhost:3000
    ports:
      - "8080:8080"

  temporal-worker:
    build: .
    user: "${UID:-1000}:${GID:-1000}"
    command: {% if dependency_manager == 'uv' %}uv run {% endif %}python manage.py run_temporal_worker
    depends_on:
      - temporal
      - db
{% if cache == 'redis' %}
      - redis
{% endif %}
    environment:
      - TEMPORAL_ADDRESS=temporal:7233
      - DATABASE_URL=postgresql://{{ project_slug }}_user:{{ project_slug }}_password@db:5432/{{ project_slug }}_db
{% if cache == 'redis' %}
      - REDIS_URL=redis://redis:6379/0
{% endif %}
    volumes:
      - .:/app
{% endif %}
{% if observability_level == 'full' %}

  jaeger:
    image: jaegertracing/all-in-one:latest
    ports:
      - "16686:16686"  # UI
      - "4318:4318"    # OTLP gRPC
    environment:
      COLLECTOR_OTLP_ENABLED: "true"
{% endif %}

volumes:
  postgres_data:
{% if cache == 'redis' or background_tasks in ['celery', 'both'] %}
  redis_data:
{% endif %}
