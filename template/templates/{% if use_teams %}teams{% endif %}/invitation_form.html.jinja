{% raw %}{% extends "base.html" %}

{% block title %}Invite to {{ view.team.name }}{% endblock %}

{% block content %}
<h1>Invite to {{ view.team.name }}</h1>
<form method="post">
    {% csrf_token %}
    {{ form.as_p }}
    <button type="submit">Send invitation</button>
</form>
{% endblock %}{% endraw %}
